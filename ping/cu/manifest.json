{
  "name": "CU",
  "description": "AMD Compute Unit component.",
  "builder_package": "github.com/sarchlab/mgpusim/v4/amd/timing/cu",
  "ports": [
    { "name": "Top" },
    { "name": "Ctrl" },
    { "name": "VectorMem" },
    { "name": "ScalarMem" },
    { "name": "InstMem" }
  ],
  "parameters": [
    { "name": "frequency",  "type": "float", "unit": "Hz", "default": 1000000000 },
    { "name": "VGPRCount",  "type": "int[]",               "default": [32768, 32768, 32768, 32768] },
    { "name": "instMem",    "type": "port",                 "default": "null", "codegen": false },
    { "name": "scalarMem",  "type": "port",                 "default": "null", "codegen": false },
    { "name": "vectorMem",  "type": "port",                 "default": "null", "codegen": false },
    { "name": "SIMDCount",  "type": "int",                  "default": 4 }
  ]
}
