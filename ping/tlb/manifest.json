{
  "name": "TLB",
  "description": "Translation Lookaside Buffer aligned with Akita's tlb builder.",
  "builder_package": "github.com/sarchlab/akita/v4/mem/vm/tlb",
  "ports": [
    { "name": "Top" },
    { "name": "Bottom" }
  ],
  "parameters": [
    { "name": "frequency",                      "type": "float",  "unit": "Hz", "default": 1000000000 },
    { "name": "numWays",                         "type": "int",                  "default": 8 },
    { "name": "numSets",                         "type": "int",                  "default": 8 },
    { "name": "log2PageSize",                    "type": "int",                  "default": 12 },
    { "name": "numReqPerCycle",                  "type": "int",                  "default": 2 },
    { "name": "addressMapperType",               "type": "string",               "default": "single", "codegen": false },
    { "name": "translationProviderMapperType",   "type": "string",               "default": "single" },
    { "name": "translationProviders",            "type": "port",                 "default": "null" },
    { "name": "remotePorts",                     "type": "port",                 "default": "null", "codegen": false }
  ]
}
